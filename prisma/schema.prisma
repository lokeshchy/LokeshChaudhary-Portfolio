generator client {
  provider = "prisma-client-js"
}

// PostgreSQL: set DATABASE_URL in your environment (local .env / Vercel env vars)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  resetTokens PasswordResetToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String   // JSON: sections, hero, etc.
  seoTitle  String?
  seoDesc   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String   @id @default(uuid())
  role        String
  organization String
  location    String?
  startDate   String
  endDate     String   // "Present" or date
  description String   // JSON array of bullet points
  type        String   // Work | Research | Internship | Volunteer
  order       Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   // Markdown
  excerpt     String?
  featuredImage String?
  tags        String   // JSON array
  published   Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  overview     String
  problem      String?
  process      String?
  solution     String?
  result       String?
  techStack    String   // JSON array
  imageGallery String   // JSON array of URLs
  featured     Boolean  @default(false)
  deployed     Boolean  @default(false)
  demoUrl      String?
  viewCode     Boolean  @default(false)
  codeUrl      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Skill {
  id       String @id @default(uuid())
  name     String
  category String // GIS, Frontend, Backend, Tools, etc.
  icon     String? // icon name or URL
  order    Int    @default(0)
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String // JSON
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
